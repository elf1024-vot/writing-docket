@echo off
REM Writing Docket Backup — {{PROJECT_NAME}}
REM Generated by writing-docket skill

SET PROJECT_PATH={{PROJECT_PATH}}
SET PROJECT_SLUG={{PROJECT_SLUG}}
SET SCHEMA={{SCHEMA}}

FOR /F "tokens=1-3 delims=/ " %%a IN ("%DATE%") DO SET DATESTR=%%c-%%a-%%b
SET DATESTR=%DATESTR: =0%

REM Create backups directory if needed
IF NOT EXIST "%PROJECT_PATH%\backups\" MKDIR "%PROJECT_PATH%\backups\"

REM DB backup via pg_dump
echo Backing up database...
docker exec %PROJECT_SLUG%-postgres pg_dump -U docket_master -d %SCHEMA% --schema=%SCHEMA% > "%PROJECT_PATH%\backups\%PROJECT_SLUG%-%DATESTR%.sql"
IF %ERRORLEVEL% NEQ 0 (
  echo ERROR: Database backup failed.
  EXIT /B 1
)
echo Database backup saved: %PROJECT_SLUG%-%DATESTR%.sql

REM Manuscript backup (Chapters, Notes, qr directories)
echo Backing up manuscripts...
powershell -Command "Compress-Archive -Path '%PROJECT_PATH%\Chapters', '%PROJECT_PATH%\Notes', '%PROJECT_PATH%\qr' -DestinationPath '%PROJECT_PATH%\backups\%PROJECT_SLUG%-manuscripts-%DATESTR%.zip' -Force"
IF %ERRORLEVEL% NEQ 0 (
  echo ERROR: Manuscript backup failed.
  EXIT /B 1
)
echo Manuscript backup saved: %PROJECT_SLUG%-manuscripts-%DATESTR%.zip

REM Prune backups older than 30 days (keep last 30)
powershell -Command "Get-ChildItem '%PROJECT_PATH%\backups\' -Filter '*.sql' | Sort-Object LastWriteTime -Descending | Select-Object -Skip 30 | Remove-Item -Force"
powershell -Command "Get-ChildItem '%PROJECT_PATH%\backups\' -Filter '*.zip' | Sort-Object LastWriteTime -Descending | Select-Object -Skip 30 | Remove-Item -Force"

echo Backup complete: %DATE% %TIME%
